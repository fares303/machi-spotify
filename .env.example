# Server port (default 3000)
PORT=3000

# Optional: YouTube Data API v3 key (improves search)
# Get free key at: https://console.cloud.google.com
YOUTUBE_API_KEY=

# Optional: Musixmatch lyrics API key
# Get free key at: https://developer.musixmatch.com
MUSIXMATCH_API_KEY=

# Optional: Genius lyrics API token
# Get free token at: https://genius.com/api-clients
GENIUS_API_TOKEN=
