# Machi Spotify Backend — Environment Variables
# Copy this file to .env:  cp .env.example .env

PORT=3001

# YouTube Data API v3 (optional — improves search quality)
# Get free key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# Musixmatch (optional — better lyrics)
# Get free key at: https://developer.musixmatch.com
MUSIXMATCH_API_KEY=

# Genius (optional — lyrics links)
# Get free key at: https://genius.com/api-clients
GENIUS_API_TOKEN=
