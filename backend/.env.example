PORT=3001

# YouTube Data API v3 (optional — app works without it via ytsr)
# Get free at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# Musixmatch (optional — for synced lyrics)
# Get free at: https://developer.musixmatch.com
MUSIXMATCH_API_KEY=

# Genius (optional — for lyrics search links)
# Get free at: https://genius.com/api-clients
GENIUS_API_TOKEN=
